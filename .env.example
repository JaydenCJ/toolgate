# Copy to .env and fill in what you need. Everything is optional.

# Slack incoming-webhook URL for approval cards
# (used by policies with `approvals.notify: [{type: slack}]`).
TOOLGATE_SLACK_WEBHOOK_URL=

# Bearer token protecting the control API (pending/approve/deny).
# Recommended on multi-user hosts; loopback-only binding is the default guard.
TOOLGATE_CONTROL_TOKEN=

# Default control API base URL for the `toolgate pending/approve/deny` CLI.
TOOLGATE_CONTROL_URL=http://127.0.0.1:9848
